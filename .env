# Database Credentials
DB_SERVER=YOUR_SERVER_NAME
DB_DATABASE=YOUR_DATABASE_NAME
DB_TABLE=YOUR_TABLE_NAME
ODBC_DRIVER=ODBC Driver 17 for SQL Server

# Legacy fallback names used by some scripts
server=YOUR_SERVER_NAME
database=YOUR_DATABASE_NAME
table=YOUR_TABLE_NAME
driver=ODBC Driver 17 for SQL Server

# Model and feature configuration
# LLM / transformers generation path (used by routing/summarization modules)
MODEL_PATH=path/to/your/llm/model
# Serialized ML prediction model (used by predict_risk)
PREDICTION_MODEL_PATH=path/to/your/prediction/model
SEMANTIC_MODEL_PATH=path/to/your/semantic/model
FEATURE_COLUMNS_PATH=path/to/feature_columns.json

# FastAPI / LLM server
APP_NAME=phishing_llm_router
USE_LLM=true
LOAD_LLM_ON_STARTUP=false
LOCAL_LLM_LOCAL_FILES_ONLY=false
MAX_NEW_TOKENS_ROUTER=200
MAX_NEW_TOKENS_SUMMARY=200
DEFAULT_TOP_N=20
DEFAULT_LIMIT=10
DEFAULT_THRESHOLD=0.60
MIN_PREDICTION_PAYLOAD_FIELDS=2
LLM_SERVER_HOST=127.0.0.1
LLM_SERVER_PORT=8001
LLM_SERVER_URL=http://127.0.0.1:8001
UI_REQUEST_TIMEOUT=120

# Cache and analytics
GLOBAL_ANALYTICS_ROWS=50000
MAX_ANALYTICS_ROWS=10000
MAX_PREDICTION_ROWS=10000
CACHE_AUTO_REFRESH_MINUTES=60
ENABLE_CACHE=true
DEFAULT_POPULATION_LIMIT=1000
HIGH_RISK_THRESHOLD=0.60
BRID_COLUMN=usertags-BRID

# Streamlit and UI
MCP_EXECUTION_MODE=mcp_stdio
MCP_SERVER_COMMAND=python
MCP_SERVER_SCRIPT=phishing_mcp_server.py
DEFAULT_USER_ROLE=user

# Logging
LOG_LEVEL=INFO